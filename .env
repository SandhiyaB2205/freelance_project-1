# ----------------------------------------------------
# FREELANCE PROJECT ENVIRONMENT VARIABLES
# ----------------------------------------------------

# --- FRONTEND SETTINGS ---
# The URL where your backend server is running
VITE_API_URL=http://localhost:5000

# --- BACKEND SETTINGS ---
# The port the backend server listens on
PORT=5000

# --- TELEGRAM NOTIFICATION SETTINGS ---
# To get these, talk to BotFather on Telegram
TELEGRAM_BOT_TOKEN=your_telegram_bot_token
TELEGRAM_CHAT_ID=your_telegram_chat_id

# --- EMAIL NOTIFICATION SETTINGS ---
# If using Gmail, use an App Password (not your main password)
EMAIL_USER=your_email@gmail.com
EMAIL_PASS=your_email_app_password

# The email address that will receive the Demo Bookings
TUTOR_EMAIL=tutor_email@gmail.com
